{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Capstone project — Claude is the primary implementer per CLAUDE.md. Settings reduce permission friction while keeping a safety net against the genuinely destructive operations.",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(git push --force origin main*)",
      "Bash(git push --force-with-lease origin main*)",
      "Bash(git push -f origin main*)",
      "Bash(git push --force origin master*)",
      "Bash(git reset --hard origin/main*)",
      "Bash(gh repo delete*)",
      "Bash(gh release delete*)",
      "Bash(rmdir /s*)",
      "Bash(Remove-Item -Recurse -Force C:\\*)",
      "Bash(Remove-Item -Recurse -Force ~*)",
      "Bash(Remove-Item -Recurse -Force $env:USERPROFILE*)"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(gh pr merge * --admin*)"
    ]
  }
}
